# Presenter prerequisites — install with: brew bundle
tap "anthropics/tap"
brew "marp-cli"             # render workshop/slides.md to HTML/PDF/PPTX
brew "rtk"                  # token-optimized CLI proxy (guardrail hook + rtk gain demo)
cask "anthropics/tap/ant"   # Anthropic CLI (ships as a cask, not a formula) — token-counter demo option B
