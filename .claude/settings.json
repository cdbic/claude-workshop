{
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -File \"$CLAUDE_PROJECT_DIR/.claude/statusline.ps1\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'exec \"$(command -v python || command -v python3)\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/rtk-guardrail.py\"'"
          }
        ]
      }
    ]
  }
}
